# === PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://knowledge:knowledge@localhost:5432/knowledge_db

# === Redis ===
REDIS_URL=redis://localhost:6379

# === PaddleOCR API Server (Docker amd64) ===
PADDLEOCR_API_URL=http://localhost:8866/ocr
OCR_MIN_CONFIDENCE=0.65

# === Qdrant ===
QDRANT_URL=http://localhost:6333

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=none

# === Ollama (EXAONE LLM) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=exaone3.5:7.8b

# === SageMaker LLM (Ollama 대신 사용 시) ===
# USE_SAGEMAKER_LLM=true  → API 서버 전체 (RAG, 분류 등)
# GRAPHRAG_USE_SAGEMAKER=true → GraphRAG 추출만
USE_SAGEMAKER_LLM=false
GRAPHRAG_USE_SAGEMAKER=false
SAGEMAKER_ENDPOINT_NAME=<your-sagemaker-endpoint>
SAGEMAKER_REGION=ap-northeast-2
# 인증 방식 (둘 중 하나):
#   - SSO/Profile: AWS_PROFILE=<profile-name> (~/.aws/config 에 SSO 설정 필요)
#   - K8s/EKS:    IRSA (IAM Role for ServiceAccount) — env 불필요
# 로컬 dev 외엔 IRSA / IAM Role 권장.
# AWS_PROFILE=

# === BGE-M3 Embedding ===
# USE_CLOUD_EMBEDDING=true → 클라우드 TEI, false → 로컬 Ollama/ONNX fallback
USE_CLOUD_EMBEDDING=true
BGE_TEI_URL=http://localhost:8080
RERANKER_TEI_URL=http://localhost:8081

# === BGE-M3 ONNX Embedding (fallback if TEI not available) ===
# FP32 모델: huggingface-cli download BAAI/bge-m3 --local-dir ./models/bge-m3
# INT8 양자화 (2-3x 빠름): python scripts/quantize_bge_m3.py
KNOWLEDGE_BGE_ONNX_MODEL_PATH=./models/bge-m3
# INT8 사용 시:
# KNOWLEDGE_BGE_ONNX_MODEL_PATH=./models/bge-m3-int8
# KNOWLEDGE_BGE_ONNX_FILE_NAME=model_quantized.onnx

# === Pipeline ===
KNOWLEDGE_PIPELINE_RUNTIME_BASE_DIR=/tmp/knowledge-local
KNOWLEDGE_PIPELINE_MAX_WORKERS=4
KNOWLEDGE_PIPELINE_BATCH_SIZE=50

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000

# === Environment / Production Hardening ===
# APP_ENV=production:
#   - CORS_ORIGINS 명시 강제 (와일드카드 금지)
#   - RATE_LIMIT_ENABLED 기본값 true (명시적 false 가능)
APP_ENV=development

# === Sentry (에러 추적, env-driven — DSN 없으면 no-op) ===
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production    # 기본 APP_ENV
# SENTRY_RELEASE=<git-sha>         # 배포 버전 태그
# SENTRY_TRACES_SAMPLE_RATE=0.1    # 0.0~1.0 (성능 모니터링; 비용 주의)
# SENTRY_PROFILES_SAMPLE_RATE=0.0

# === OpenTelemetry tracing (env-driven — endpoint 없으면 no-op) ===
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318  # OTLP HTTP. 없으면 비활성
# OTEL_SERVICE_NAME=axiomedge-api
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1   # 10% 샘플링 (production)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_SCOPE=user_or_ip  # ip(default) | user | user_or_ip — per-tenant quota
# RATE_LIMIT_MAX_KEYS=50000    # LRU cap on distinct buckets (memory bound)
# TRUST_PROXY_HEADERS=true   # reverse proxy(nginx/CF) 뒤일 때만. 직접 노출 시 끄지 않으면 IP 위변조 가능

# === Dashboard ===
DASHBOARD_API_URL=http://localhost:8000
