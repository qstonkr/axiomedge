<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.gs.edge-server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/edge-model/current-app/edge-server</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>STORE_ID</key>
        <string>unknown</string>
        <key>MODEL_PATH</key>
        <string>/opt/edge-model/models/current/model.gguf</string>
        <key>LOG_DIR</key>
        <string>/opt/edge-model/logs</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/opt/edge-model/logs/server.log</string>
    <key>StandardErrorPath</key>
    <string>/opt/edge-model/logs/server.err</string>
</dict>
</plist>
